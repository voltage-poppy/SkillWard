# Guardian API Configuration
# Settings can also be configured via the UI (Settings panel)
# and are persisted to ~/.guardian/settings.json
#
# Note: Docker image, safety threshold, timeouts and retry settings are
# now CLI args of guardian.py with sensible defaults — no need to set them here.

# ── Provider shortcut ────────────────────────────────────────────────
# A single GUARDIAN_PROVIDER drives BOTH:
#   • Stage 1 (host litellm safety scoring)
#   • Stage 2 (in-container OpenClaw agent)
#
# Known providers (see PROVIDER_TABLE in config.py):
#   azure, openai, anthropic, gemini, zhipu, minimax, moonshot, qwen,
#   deepseek, doubao, xai, groq, openrouter, mistral, ollama
GUARDIAN_PROVIDER=
GUARDIAN_MODEL_ID=
GUARDIAN_API_KEY=
GUARDIAN_API_BASE=
GUARDIAN_API_VERSION=

# ── Escape hatches (optional, override the auto-derived values) ──────
# Use these only if Stage 1 / Stage 2 need different model strings
# or your provider is not in PROVIDER_TABLE.
# GUARDIAN_LLM_MODEL=
# GUARDIAN_LLM_BASE_URL=
# GUARDIAN_DOCKER_MODEL=
# GUARDIAN_DOCKER_API_URL=

# ── Guard Plugin inside Docker container (runtime interception) ──────
# API URL: overrides the plugin's default (http://api.fangcunleap.com/v1/guardrails)
# API Key: replaces the hardcoded key in the container's plugin
GUARDIAN_GUARD_PLUGIN_API_URL=
GUARDIAN_GUARD_PLUGIN_API_KEY=
